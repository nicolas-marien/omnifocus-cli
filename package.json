{
  "name": "omnifocus-cli",
  "version": "0.1.0",
  "description": "CLI for OmniFocus automation on macOS",
  "license": "MIT",
  "bin": {
    "of": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "citty": "0.2.1"
  }
}
